<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    ConnectEase BDD Combined Suite
    ================================
    Single XML for both Smoke and Regression BDD runs.

    To run ALL tests     : keep both <test> blocks enabled="true"
    To run Smoke only    : set Regression block to enabled="false"
    To run Regression only : set Smoke block to enabled="false"

    Listeners are declared once at <suite> level and automatically apply
    to every <test> block inside — same behaviour as the individual XMLs.
-->
<suite name="ConnectEase BDD Suite" verbose="1" thread-count="1" preserve-order="true">

    <listeners>
        <listener class-name="org.testng.reporters.EmailableReporter2"/>
        <listener class-name="com.cts.connectease.bdd.reports.BddSuiteListener"/>
    </listeners>

    <!-- ── Smoke: flip enabled="false" to skip this block ── -->
    <test name="Smoke — UI and API Tests" preserve-order="true" enabled="true">
        <classes>
            <class name="com.cts.connectease.bdd.runners.SmokeTestRunner"/>
        </classes>
    </test>

    <!-- ── Regression: flip enabled="false" to skip this block ── -->
    <test name="Regression — UI and API Tests" preserve-order="true" enabled="true">
        <classes>
            <class name="com.cts.connectease.bdd.runners.RegressionTestRunner"/>
        </classes>
    </test>

</suite>
