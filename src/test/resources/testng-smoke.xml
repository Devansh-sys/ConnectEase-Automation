<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="ConnectEase BDD Smoke Suite" verbose="1" thread-count="1" preserve-order="true">
    <listeners>
        <listener class-name="org.testng.reporters.EmailableReporter2"/>
        <listener class-name="com.cts.connectease.bdd.reports.BddSuiteListener"/>
    </listeners>
    <test name="Smoke — UI and API Tests" preserve-order="true">
        <classes>
            <class name="com.cts.connectease.bdd.runners.SmokeTestRunner"/>
        </classes>
    </test>
</suite>
